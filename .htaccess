<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Forward all /api/... calls to api.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ api.php?_route=$1 [QSA,L]
    
    # 2. SPA routing fallback for React router (HTML5 History API)
    # If the requested path is not an actual file or directory, serve index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>
